{
	"name": "@stratiqai/widget-mapbox-3d",
	"version": "0.1.0",
	"stratiqai": {
		"widget": true,
		"manifest": "./src/lib/index.ts",
		"manifestExport": "mapbox3dWidget"
	},
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
