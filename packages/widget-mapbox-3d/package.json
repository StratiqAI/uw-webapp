	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "svelte-package -i src/lib -o dist",
		"dev": "svelte-package -i src/lib -o dist --watch"
	},
	"peerDependencies": {
		"@stratiqai/dashboard-widget-sdk": "^0.1.0",
		"mapbox-gl": "^3.0.0",
		"svelte": "^5.0.0",
		"zod": "^3.0.0"
	},
	"devDependencies": {
		"@stratiqai/dashboard-widget-sdk": "^0.1.0",
		"@sveltejs/package": "^2.0.0",
		"@types/mapbox__mapbox-gl-geocoder": "^5.1.1",
		"mapbox-gl": "^3.0.0",
		"svelte": "^5.0.0",
		"typescript": "^5.0.0",
		"zod": "^3.0.0"
	},
	"dependencies": {
		"@mapbox/mapbox-gl-geocoder": "^5.1.2"
	}
}
