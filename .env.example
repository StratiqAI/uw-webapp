# Public Environment Variables (accessible in browser)
# These variables are prefixed with PUBLIC_ to make them available client-side
# WARNING: These will be exposed in the client bundle. Only use for non-sensitive keys
# or keys that are meant to be public.

# OpenAI API Key for AI Client
PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key for AI Client
PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (public anon key — exposed in browser; protect with RLS)
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Server-only: Google Vertex / Gemini (ADC) ---
# Never use PUBLIC_ for these. On Vercel: Settings → Environment Variables → Sensitive.
#
# Preferred for deploys without a repo file: paste the full service account JSON as one line (minified).
# Lookup order: GOOGLE_APPLICATION_CREDENTIALS_JSON, then GOOGLE_SERVICE_ACCOUNT_JSON, then GOOGLE_SERVICE_ACCOUNT.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
#
# When using JSON above, remove GOOGLE_APPLICATION_CREDENTIALS or leave only a path that exists on disk.
# (If that path is missing, the server clears it so google-auth does not ENOENT before JSON is applied.)
#
# Local dev alternative: path to a downloaded key file (relative paths are resolved from cwd).
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json
#
# GOOGLE_PROJECT_ID=your-gcp-project-id
# GOOGLE_LOCATION=us-central1

# --- GitHub Packages (@stratiqai/*) ---
# Required for `npm install` when dependencies resolve from npm.pkg.github.com (see root `.npmrc`).
# Create a GitHub PAT with **read:packages** (classic) or fine-grained "Packages: Read" for the owning org/repo.
# On Vercel: Project → Settings → Environment Variables → add NPM_TOKEN for Production/Preview (Sensitive).
# Local: export NPM_TOKEN=ghp_... or put in a shell profile (never commit).
# NPM_TOKEN=
